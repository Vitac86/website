LEAD_PROVIDER=email

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=<SMTP_SENDER_EMAIL>
SMTP_PASS=<SMTP_APP_PASSWORD>
SMTP_TO=<SMTP_RECIPIENT_EMAIL>

WEBHOOK_URL=

# Required for rendering Cloudflare Turnstile on the client
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Required for server-side Turnstile verification
TURNSTILE_SECRET_KEY=

# Required for lead rate limiting and duplicate protection
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

LEAD_RATE_LIMIT_MAX=5
LEAD_RATE_LIMIT_WINDOW=30 m
LEAD_MIN_FILL_MS=3000
LEAD_DUPLICATE_WINDOW_HOURS=24
LEAD_DUPLICATE_MAX_ACCEPTED=2
